[Unit]
Description=PiRouter Pro Dashboard
After=network.target

[Service]
Type=simple
User=pi
# ⚠️ Update WorkingDirectory and ExecStart to match your clone path
WorkingDirectory=/home/pi/PiRoute
ExecStart=/usr/bin/python3 /home/pi/PiRoute/app.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
Environment=PATH=/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
