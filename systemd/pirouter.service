[Unit]
Description=PiRouter Pro Dashboard
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/var/www/pirouter-pro
ExecStart=/usr/bin/python3 /var/www/pirouter-pro/app.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
Environment=PATH=/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
